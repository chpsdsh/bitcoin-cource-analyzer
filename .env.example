# Optional overrides for OAuth2 / OIDC.
# You can run the project without this file: by default it uses the built-in local OIDC provider on http://host.docker.internal:8086
# If you want to switch to an external provider, copy this file to .env and adjust the values below.
# Docker Desktop needs host.docker.internal here; Linux runners can omit it and use the docker-compose default localhost value.

GELF_ADDRESS=udp://host.docker.internal:12201

AUTH_PROVIDER_PUBLIC_ISSUER=http://host.docker.internal:8086
AUTH_PROVIDER_CLIENT_ID=btr-local-client
AUTH_PROVIDER_CLIENT_SECRET=btr-local-secret
AUTH_PROVIDER_COOKIE_SECURE=false
AUTH_PROVIDER_CAPTCHA_ENABLED=true
AUTH_PROVIDER_CAPTCHA_PROVIDER=turnstile
AUTH_PROVIDER_CAPTCHA_SITE_KEY=
AUTH_PROVIDER_CAPTCHA_SECRET_KEY=
AUTH_PROVIDER_CAPTCHA_THRESHOLD=5
AUTH_PROVIDER_CAPTCHA_WINDOW_SECONDS=900
AUTH_PROVIDER_CAPTCHA_VERIFY_TIMEOUT_SECONDS=5

OAUTH2_PROXY_PROVIDER=oidc
OAUTH2_PROXY_OIDC_ISSUER_URL=http://host.docker.internal:8086
OAUTH2_PROXY_CLIENT_ID=btr-local-client
OAUTH2_PROXY_CLIENT_SECRET=btr-local-secret
OAUTH2_PROXY_COOKIE_SECRET=sBz2mI8QZ0Ih1x8nV9gL5dWf4JqR7uYp4A1kC6tN3eM
OAUTH2_PROXY_REDIRECT_URL=http://localhost:8085/oauth2/callback
OAUTH2_PROXY_EMAIL_DOMAINS=*
OAUTH2_PROXY_SCOPE=openid profile email
OAUTH2_PROXY_COOKIE_SECURE=false
OAUTH2_PROXY_WHITELIST_DOMAINS=localhost:8085,localhost:8086,host.docker.internal:8086
